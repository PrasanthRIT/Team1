<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Drivers</title>
    <link rel="stylesheet" href="/css/tigerboard-theme.css">
</head>
<body>

<header>
    <a href="/" class="logo-container">
        <img src="/logo.jpg" alt="TigerBoard Logo" class="logo-img" onerror="this.style.display='none'">
    </a>
</header>

<main>
    <div class="section-header stack">
        <h2>Drivers List</h2>
        <p class="section-subtitle">View all registered drivers in the system.</p>
    </div>

    <div class="action-row">
        <a href="/" class="btn btn-outline">Home</a>
        <a href="/drivers/add" class="btn btn-primary">Add Driver</a>
    </div>

    <div class="table-card">
        <div class="table-responsive">
            <table>
                <thead>
                <tr>
                    <th>ID</th>
                    <th>First Name</th>
                    <th>Last Name</th>
                    <th>License Number</th>
                    <th>Phone</th>
                    <th>Assigned Buses</th>
                </tr>
                </thead>
                <tbody>
                {{#driverList}}
                    <tr>
                        <td>{{user.id}}</td>
                        <td>{{user.firstName}}</td>
                        <td>{{user.lastName}}</td>
                        <td>{{licenseNumber}}</td>
                        <td>{{phoneNumber}}</td>
                        <td>{{#assignedBusNumbers}}{{.}} {{/assignedBusNumbers}}</td>
                    </tr>
                {{/driverList}}

                {{^driverList}}
                    <tr>
                        <td colspan="6">No drivers available.</td>
                    </tr>
                {{/driverList}}
                </tbody>
            </table>
        </div>
    </div>
</main>

</body>
</html>