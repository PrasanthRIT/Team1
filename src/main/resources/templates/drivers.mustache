<!DOCTYPE html>
<html>
<head>
    <title>Drivers</title>
</head>
<body>

<h1>Drivers List</h1>

<a href="/add-drivers">Add Driver</a>

<table border="1">
    <tr>
        <th>ID</th>
        <th>License Number</th>
        <th>Phone</th>
    </tr>

    {{#driverList}}
        <tr>
            <td>{{id}}</td>
            <td>{{licenseNumber}}</td>
            <td>{{phoneNumber}}</td>
        </tr>
    {{/driverList}}

</table>

</body>
</html>