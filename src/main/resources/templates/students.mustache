<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>TigerBoard | Student-User</title>
    <link rel="stylesheet" href="/css/tigerboard-theme.css">
</head>
<body>

<header>
    <a href="/" class="logo-container">
        <img src="/logo.jpg" alt="TigerBoard Logo" class="logo-img">
        <p style="color: black; font-size: 26px; font-weight: bold">TigerBoard</p>
    </a>
</header>

<main>
    <div class="section-header">
        <a href="/" class="btn btn-outline">Back to Home</a>
        <h2>Student Table</h2>
        <a href="/students/add" class="btn btn-primary">Add New Student</a>
    </div>

    <div class="table-card">
        <div class="table-responsive">
            <table>
                <thead>
                <tr>
                    <th>First Name</th>
                    <th>Last Name</th>
                    <th>Password Hash</th>
                    <th>Commute Plan</th>
                    <th>Location</th>
                    <th>Bus Assigned</th>
                </tr>
                </thead>
                <tbody>
                {{#StdList}}
                    <tr>
                        <td><strong>{{user.firstName}}</strong></td>
                        <td>{{user.lastName}}</td>
                        <td>{{user.passwordHash}}</td>
                        <td>{{commutePlan}}</td>
                        <td>{{location}}</td>
                        <td>{{assignedBus}}</td>
                    </tr>
                {{/StdList}}
                </tbody>
            </table>
        </div>
    </div>
</main>

</body>
</html>