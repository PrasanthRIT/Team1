<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>TigerBoard - Users</title>
    <link rel="stylesheet" href="/css/tigerboard-theme.css">
</head>
<body>

<!-- Header Section -->
<header>
    <a href="#" class="logo-container">
        <img src="/logo.jpg" alt="Tiger Logo" class="logo-img" onerror="this.style.display='none'">
    </a>
</header>

<!-- Main Content -->
<main>
    <div class="section-header">
        <h2>Active Commuters</h2>
    </div>

    <!-- Table Container -->
    <div class="table-card">
        <div class="table-responsive">
            <table>
                <thead>
                <tr>
                    <th>User ID</th>
                    <th>Email</th>
                    <th>First Name</th>
                    <th>Last Name</th>
                    <th>Role</th>
                </tr>
                </thead>
                <tbody>
                {{#usersList}}
                <tr>
                    <td>{{id}}</td>
                    <td>{{emailID}}</td>
                    <td>{{firstName}}</td>
                    <td>{{lastName}}</td>
                    <td>{{userRole}}</td>
                </tr>
                {{/usersList}}
                </tbody>
            </table>
        </div>
    </div>

    <div class="action-row">
        <a href="/" class="btn btn-outline" title="Return to Home">Home</a>
        <label for="add-user-modal" class="btn btn-primary">Add User</label>
    </div>
</main>

</body>
</html>

