<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>TigerBoard | Success</title>
    <link rel="stylesheet" href="/css/tigerboard-theme.css">
</head>
<body>
<header>
    <a href="/" class="logo-container">
        <img src="/logo.jpg" alt="Tiger Logo" class="logo-img" onerror="this.style.display='none'">
    </a>
</header>

<main>
    <div class="section-header">
        <h2>Success</h2>
    </div>

    <div class="form-card">
        <p>Thank you. {{#isBuse}}bus{{/isBuse}}{{^isBuse}}{{entityName}}{{/isBuse}} data was added successfully!</p>
        <div class="action-row">
            <a href="/" class="btn btn-outline">Home</a>
            <a href="/{{entityName}}s" class="btn btn-primary">View all {{entityName}}s</a>
        </div>
    </div>
</main>
</body>
</html>