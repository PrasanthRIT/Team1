<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>TigerBoard - Add User</title>
    <link rel="stylesheet" href="/css/tigerboard-theme.css">
</head>
<body>
<!-- Header Section -->
<header>
    <a href="#" class="logo-container">
        <img src="/logo.jpg" alt="Tiger Logo" class="logo-img" onerror="this.style.display='none'">
    </a>
</header>

<main>
    <div class="section-header">
        <h2>Add New User</h2>
    </div>

    <form action="/users/add" method="post" class="form-card form-grid">
        <div class="form-field">
            <label class="form-label" for="firstName">First Name</label>
            <input id="firstName" class="form-control" type="text" name="firstName" placeholder="First Name" required>
        </div>

        <div class="form-field">
            <label class="form-label" for="lastName">Last Name</label>
            <input id="lastName" class="form-control" type="text" name="lastName" placeholder="Last Name" required>
        </div>

        <div class="form-field">
            <label class="form-label" for="email">Email</label>
            <input id="email" class="form-control" type="text" name="email" placeholder="Email" required>
        </div>

        <div class="form-field">
            <label class="form-label" for="roleSelect">Role</label>
            <select class="form-control" name="role" id="roleSelect" onchange="toggleFields()">
                <option value="Student" {{#isStudent}}selected{{/isStudent}}>Student</option>
                <option value="Driver" {{#isDriver}}selected{{/isDriver}}>Driver</option>
                <option value="Supervisor">Supervisor</option>
            </select>
        </div>

        <div id="studentFields" class="form-section">
            <div class="form-field">
                <label class="form-label" for="commutePlan">Commute Plan</label>
                <select id="commutePlan" class="form-control" name="commutePlan">
                    <option value="MORNING_ONLY">Morning Only</option>
                    <option value="EVENING_ONLY">Evening Only</option>
                    <option value="ROUND_TRIP">Round Trip</option>
                </select>
            </div>

            <div class="form-field">
                <label class="form-label" for="location">Location</label>
                <input id="location" class="form-control" type="text" name="location" placeholder="e.g. Al Barsha">
            </div>

            <div class="form-field">
                <label class="form-label">Assigned Bus</label>
                <select class="form-control" name="assignedBusNumber">
                    {{#busList}}
                        <option value="{{busNumber}}">Bus {{busNumber}} — {{route}}</option>
                    {{/busList}}
                </select>
            </div>
        </div>

        <div id="driverFields" class="form-section" style="display:none;">
            <div class="form-field">
                <label class="form-label" for="licenseNumber">License Number</label>
                <input id="licenseNumber" class="form-control" type="text" name="licenseNumber" placeholder="e.g. DL-9921">
            </div>

            <div class="form-field">
                <label class="form-label" for="phoneNumber">Phone Number</label>
                <input id="phoneNumber" class="form-control" type="text" name="phoneNumber" placeholder="e.g. 050-123-4567">
            </div>
        </div>

        <div class="form-actions">
            <button type="submit" class="btn btn-primary">Add</button>
            <a href="/" class="btn btn-outline">Home</a>
        </div>
    </form>
</main>

<script>
    function toggleFields() {
        var role = document.getElementById("roleSelect").value;
        document.getElementById("studentFields").style.display =
                role === "Student" ? "grid" : "none";
        document.getElementById("driverFields").style.display =
                role === "Driver" ? "grid" : "none";
    }

    toggleFields();
</script>

</body>
</html>