<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Add New Bus - TigerBoard</title>

    <link rel="stylesheet" href="/css/tigerboard-theme.css">

    <style>

        header .logo-img {
            height: 50px;
        }

        .section-header{
            justify-content: center;
        }

        .table-card {
            padding: 2.5rem;
        }

        .field{
            margin-bottom: 1.5rem;
        }

        .field-input {
            width: 100%;
            padding: 1rem;
            border: 1px solid var(--border-color);
            border-radius: 5px;
            font-size: 1rem;
            transition: all 0.25s;
        }

        .field-input:focus {
            outline: none;
            border-color: var(--primary-blue);
            box-shadow: 0 0 0 4px rgba(0, 162, 232, 0.1);
        }

        .field-buttons {
            display: flex;
            align-items: center;
            gap: 1rem;
            margin-top: 2rem;
        }

        .btn-back {
            margin-right: auto;
        }

        .btn-cancel {
            margin-left: auto;
        }

        label {
            font-weight: 600;
        }

    </style>

</head>
<body>

<header>
    <a href="/" class="logo-container">
        <img src="/logo.jpg" alt="TigerBoard Logo" class="logo-img">
        <p style="color: black; font-size: 26px; font-weight: bold">TigerBoard</p>
    </a>
</header>

<main>

    <div class="section-header">
        <h2>Add a New Bus</h2>
    </div>

    <!--Uses linked CSS to style fields and buttons-->
    <div class="table-card">
        <form action="/buses/add" method="POST">
            <div class="field">
                <label>Bus Number</label>
                <input type="text" name="busNumber" class="field-input" placeholder="e.g. 26" required>
            </div>

            <div class="field">
                <label>Passenger Capacity</label>
                <input type="number" name="capacity" class="field-input" placeholder="Total seats" required>
            </div>

            <div class="field">
                <label>Route Detail</label>
                <input type="text" name="route" class="field-input" placeholder="e.g. Sharjah to RIT Dubai" required>
            </div>

            <div class="field">
                <label>Status</label>
                <select name="isActive" class="field-input">
                    <option value="true">Active</option>
                    <option value="false">Inactive</option>
                </select>
            </div>

            <div class="field-buttons">
                <a href="/" class="btn btn-outline btn-back">Back to Home</a>
                <a href="/buses" class="btn btn-outline btn-cancel">Cancel</a>
                <button type="submit" class="btn btn-primary btn-save">Save Bus Record</button>
            </div>
        </form>
    </div>

</main>
</body>
</html>